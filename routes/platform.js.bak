// POST /api/platform/invitations - Create owner invitation
router.post('/invitations', verifyPlatformAdmin, async (req, res) => {
  const { email, store_id, role_id } = req.body;
  if (!email || !store_id) {
    return res.status(400).json({ error: 'Email and store_id are required' });
  }

  try {
    let targetRoleId = role_id;
    if (!targetRoleId) {
      targetRoleId = await ensureOwnerTemplateRole();
    }

    const token = crypto.randomBytes(32).toString('hex');
    const expiresAt = new Date(Date.now() + 48 * 60 * 60 * 1000).toISOString(); // 48 hours expiry

    const { data: invitation, error } = await supabase
      .from('tenant_invitations')
      .insert([{
        email: email.trim().toLowerCase(),
        store_id,
        role_id: targetRoleId,
        token,
        status: 'pending',
        expires_at: expiresAt,
        invited_by: req.user?.sub || null, // from auth middleware
        created_ip: req.ip
      }])
      .select()
      .single();

    if (error) throw error;
    await auditPlatform(req, 'platform.invitation.create', 'tenant_invitation', invitation.id, {}, invitation, store_id);

    // Send notification
    const { sendNotification } = require('../services/notificationEngine');
    const activationLink = `${process.env.FRONTEND_URL || 'https://egparts.store'}/accept-invitation?token=${token}`;
    
    // We send via email (run in background to prevent API hanging if SMTP is slow/blocked)
    sendNotification({
      templateCode: 'tenant_invitation',
      recipient: email.trim(),
      variables: {
        activation_link: activationLink,
        expires_hours: 48,
        email: email.trim()
      }
    }).catch(err => logger.error('Failed to send invitation email in background:', err));

    res.json({ success: true, invitation });
  } catch (err) {
    logger.error('Failed to create invitation:', err.message);
    res.status(500).json({ error: 'Failed to create invitation: ' + err.message });
  }
});

// POST /api/platform/invitations/:id/resend - Resend invitation
router.post('/invitations/:id/resend', verifyPlatformAdmin, async (req, res) => {
  const { id } = req.params;
  try {
    const { data: invite, error: fetchErr } = await supabase
      .from('tenant_invitations')
      .select('*')
      .eq('id', id)
      .single();

    if (fetchErr || !invite) {
      return res.status(404).json({ error: 'Invitation not found' });
    }

    const token = crypto.randomBytes(32).toString('hex');
    const expiresAt = new Date(Date.now() + 48 * 60 * 60 * 1000).toISOString();

    const { data: updated, error: updateErr } = await supabase
      .from('tenant_invitations')
      .update({
        token,
        status: 'sent',
        expires_at: expiresAt,
        resent_count: (invite.resent_count || 0) + 1,
        created_ip: req.ip,
        updated_at: new Date().toISOString()
      })
      .eq('id', id)
      .select()
      .single();

    if (updateErr) throw updateErr;

    const { sendNotification } = require('../services/notificationEngine');
    const activationLink = `${process.env.FRONTEND_URL || 'https://egparts.store'}/accept-invitation?token=${token}`;
    
    // Run in background to prevent API hanging if SMTP is slow/blocked
    sendNotification({
      templateCode: 'tenant_invitation',
      recipient: invite.email,
      variables: {
        activation_link: activationLink,
        expires_hours: 48,
        email: invite.email
      }
    }).catch(err => logger.error('Failed to resend invitation email in background:', err));

    res.json({ success: true, invitation: updated });
  } catch (err) {
    logger.error('Failed to resend invitation:', err.message);
    res.status(500).json({ error: 'Failed to resend invitation' });
  }
});

// POST /api/platform/invitations/:id/revoke - Revoke invitation
router.post('/invitations/:id/revoke', verifyPlatformAdmin, async (req, res) => {
