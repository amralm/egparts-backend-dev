PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhb...
FRONTEND_URL=http://localhost:5173

# Security & Encryption
OAUTH_ENCRYPTION_SECRET=a-very-secure-encryption-secret-32b-key
DATABASE_ENCRYPTION_KEY=your-database-encryption-key-32b

# Redis (Rate Limiting, Queues)
REDIS_URL=redis://localhost:6379

# Third Party
PAYMOB_API_KEY=your-paymob-api-key
WHATSAPP_API_URL=http://localhost:8000
WHATSAPP_API_KEY=your-whatsapp-api-key

# Vite (Frontend)
VITE_API_URL=http://localhost:3000
VITE_BACKEND_URL=http://localhost:3000
VITE_APP_VERSION=1.0.0
VITE_DEFAULT_STORE_SUBDOMAIN=egparts
VITE_GIT_COMMIT=development
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SENTRY_DSN=https://your-dsn@ingest.de.sentry.io/project

# Sentry
SENTRY_AUTH_TOKEN=your-sentry-auth-token
